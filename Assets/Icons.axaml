<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Lucide-style line icons on a 24x24 viewbox, rendered with Path + Stroke. -->

    <!-- square-pen / compose (New session) -->
    <StreamGeometry x:Key="IcoCompose">M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.4 2.6a2 2 0 0 1 2.8 2.8L12 14.6l-4 1 1-4z</StreamGeometry>

    <!-- search -->
    <StreamGeometry x:Key="IcoSearch">M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14 M21 21l-4.3-4.3</StreamGeometry>

    <!-- clock (scheduled) -->
    <StreamGeometry x:Key="IcoClock">M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18 M12 7v5l3 2</StreamGeometry>

    <!-- folder (Files) -->
    <StreamGeometry x:Key="IcoFolder">M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.7-.9l-.8-1.2A2 2 0 0 0 7.9 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2z</StreamGeometry>

    <!-- settings (gear) -->
    <StreamGeometry x:Key="IcoSettings">M19.4 13a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1.1-1.5 1.7 1.7 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.8 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.5-1.1 1.7 1.7 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.8.3H9a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.8V9a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z</StreamGeometry>

    <!-- plus -->
    <StreamGeometry x:Key="IcoPlus">M5 12h14 M12 5v14</StreamGeometry>

    <!-- arrow-up (send) -->
    <StreamGeometry x:Key="IcoArrowUp">M12 19V5 M6 11l6-6 6 6</StreamGeometry>

    <!-- panel-left (sidebar collapse) -->
    <StreamGeometry x:Key="IcoPanel">M4 4h16a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z M9 4v16</StreamGeometry>

    <!-- arrow-left -->
    <StreamGeometry x:Key="IcoArrowLeft">M19 12H5 M12 19l-7-7 7-7</StreamGeometry>

    <!-- arrow-right -->
    <StreamGeometry x:Key="IcoArrowRight">M5 12h14 M12 5l7 7-7 7</StreamGeometry>

    <!-- chevron-down -->
    <StreamGeometry x:Key="IcoChevronDown">M6 9l6 6 6-6</StreamGeometry>

    <!-- git-branch -->
    <StreamGeometry x:Key="IcoBranch">M6 3v12 M18 6a3 3 0 1 0-6 0 3 3 0 0 0 6 0z M9 18a3 3 0 1 0-6 0 3 3 0 0 0 6 0z M15 6a9 9 0 0 1-9 9</StreamGeometry>

    <!-- sun (light theme) -->
    <StreamGeometry x:Key="IcoSun">M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z M12 2v2 M12 20v2 M4.9 4.9l1.4 1.4 M17.7 17.7l1.4 1.4 M2 12h2 M20 12h2 M6.3 17.7l-1.4 1.4 M19.1 4.9l-1.4 1.4</StreamGeometry>

    <!-- moon (dark theme) -->
    <StreamGeometry x:Key="IcoMoon">M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z</StreamGeometry>

    <!-- file (attachment / sparkle) -->
    <StreamGeometry x:Key="IcoFile">M14 3v5h5 M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z</StreamGeometry>

    <!-- sparkles (skill / build) -->
    <StreamGeometry x:Key="IcoSparkle">M12 4l1.6 4.4L18 10l-4.4 1.6L12 16l-1.6-4.4L6 10l4.4-1.6z M19 15l.7 2 2 .7-2 .7-.7 2-.7-2-2-.7 2-.7z</StreamGeometry>

    <!-- check (confirm) -->
    <StreamGeometry x:Key="IcoCheck">M20 6L9 17l-5-5</StreamGeometry>

    <!-- x (close / remove) -->
    <StreamGeometry x:Key="IcoX">M18 6L6 18 M6 6l12 12</StreamGeometry>

    <!-- copy (two overlapping squares) -->
    <StreamGeometry x:Key="IcoCopy">M9 9h10a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V10a1 1 0 0 1 1-1z M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1</StreamGeometry>

    <!-- edit (pencil) -->
    <StreamGeometry x:Key="IcoEdit">M12 20h9 M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z</StreamGeometry>

    <!-- redo / refresh (circular arrow) -->
    <StreamGeometry x:Key="IcoRedo">M21 12a9 9 0 1 1-2.6-6.4 M21 3v6h-6</StreamGeometry>

    <!-- filled dot (status) -->
    <StreamGeometry x:Key="IcoDot">M12 6a6 6 0 1 0 0 12 6 6 0 0 0 0-12z</StreamGeometry>

    <!-- external-link (open) -->
    <StreamGeometry x:Key="IcoExternal">M15 3h6v6 M10 14L21 3 M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5</StreamGeometry>

</ResourceDictionary>
